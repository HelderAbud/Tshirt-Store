# Copy this file to `.env` for local development.
# Do not use these example values in production.

DB_URL=jdbc:mysql://localhost:3306/loja_revenda
DB_USERNAME=app
DB_PASSWORD=change-me-local-app-password

MYSQL_ROOT_PASSWORD=change-me-local-root-password
MYSQL_DATABASE=loja_revenda
MYSQL_USER=app
MYSQL_PASSWORD=change-me-local-app-password

# Base64-encoded HS256 secret with at least 256 bits.
# Generate your own value before running outside local experiments.
JWT_SECRET=replace-with-base64-encoded-256-bit-secret
